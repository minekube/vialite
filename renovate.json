{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard"
  ],
  "timezone": "Europe/Berlin",
  "schedule": [
    "before 6am every weekday"
  ],
  "labels": [
    "dependencies"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^build/via\\.version$/"
      ],
      "matchStrings": [
        "^(?<currentDigest>[a-f0-9]{40})\\s*$"
      ],
      "depNameTemplate": "RaphiMC/ViaProxy",
      "packageNameTemplate": "https://github.com/RaphiMC/ViaProxy",
      "datasourceTemplate": "git-refs",
      "currentValueTemplate": "master"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^build/graalvm\\.version$/"
      ],
      "matchStrings": [
        "^(?<depName>[^:@\\s]+):(?<currentValue>[^@\\s]+)(?:@(?<currentDigest>sha256:[0-9a-f]{64}))?\\s*$"
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchManagers": [
        "custom.regex"
      ],
      "matchDepNames": [
        "RaphiMC/ViaProxy"
      ],
      "groupName": "ViaProxy upstream",
      "commitMessagePrefix": "fix(deps):",
      "commitMessageTopic": "ViaProxy",
      "commitMessageAction": "bump",
      "commitMessageExtra": "to {{newDigestShort}}",
      "labels": [
        "dependencies",
        "via-rebuild"
      ],
      "automerge": false
    }
  ],
  "ignorePaths": [
    "build/.work/**"
  ],
  "prHourlyLimit": 4,
  "prConcurrentLimit": 8,
  "rebaseWhen": "behind-base-branch"
}
